{
  "name": "backend-ecommerce",
  "version": "1.0.0",
  "description": "Backend para sistema de comercio electrónico con Node.js, Express y Sequelize",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node config/createDataBase.js",
    "reset-db": "node config/resetDatabase.js",
    "seed": "node -e \"require('./seeders/adminSeeder').runSeeders().then(() => process.exit(0)).catch((err) => { console.error(err); process.exit(1); })\"",
    "test": "jest --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "sequelize",
    "jwt",
    "mysql"
  ],
  "author": "Sebastin.an Sánchez",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.2.2"
  }
}
